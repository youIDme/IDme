# ─────────────────────────────────────────────
# IDme Environment Configuration
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Application
APP_NAME=IDme
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
PUBLIC_URL=https://idme.io

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://idme:CHANGE_ME_DB_PASSWORD@postgres:5432/idme

# Redis 7.2
REDIS_URL=redis://redis:6379/0

# Secret key for session tokens & Fernet encryption
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# GitHub OAuth
# Create app at: https://github.com/settings/developers
# Callback URL: https://idme.io/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LinkedIn OAuth
# Create app at: https://www.linkedin.com/developers/apps
# Callback URL: https://idme.io/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook OAuth
# Create app at: https://developers.facebook.com/apps
# Callback URL: https://idme.io/oauth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# WhatsApp via Twilio (Optional — for OTP verification in v1.1)
# Sign up at: https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Session
SESSION_TOKEN_LENGTH=64

# Slug cleanup (hours before unclaimed slugs are released)
SLUG_EXPIRY_HOURS=24
